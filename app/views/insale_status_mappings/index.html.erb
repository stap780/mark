<div class="flex items-center justify-between mb-4">
  <div class="flex items-center gap-2">
    <%= link_to t("back"), account_insales_path(current_account), class: "inline-flex items-center px-3 py-1 bg-white text-violet-600 border border-violet-500 rounded-md hover:bg-violet-50" %>
    <h1 class="text-xl font-semibold"><%= t(".title") %></h1>
  </div>
  <%= link_to_new new_account_insale_insale_status_mapping_path(current_account, @insale), data: { turbo_frame: :offcanvas } %>
</div>

<div class="bg-white rounded-lg shadow divide-y">
  <div class="grid grid-cols-[1fr_1fr_2fr_120px] gap-4 p-4 font-medium text-gray-700">
    <div><%= t(".custom_status", default: "Custom status") %></div>
    <div><%= t(".financial_status", default: "Financial status") %></div>
    <div><%= t(".incase_status", default: "Статус заявки") %></div>
    <div></div>
  </div>
  <%= turbo_frame_tag dom_id(@insale, :insale_status_mappings) do %>
    <%= render @insale_status_mappings %>
  <% end %>
</div>
