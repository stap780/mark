<% content_for :title, "Заявки клиентов" %>

<% current_webform_id = params[:webform_id].presence || params.dig(:q, :webform_id_eq) %>
<div class="flex flex-wrap gap-2 mb-4">
  <%= link_to t('incases.index.all'),
      account_incases_path(current_account),
      class: "px-3 py-1 rounded-md #{current_webform_id.blank? ? 'bg-violet-600 text-white' : 'bg-gray-200 hover:bg-gray-300'}",
      data: { turbo: false } %>
  <% @webforms.each do |wf| %>
    <%= link_to wf.title,
        account_incases_path(current_account, webform_id: wf.id),
        class: "px-3 py-1 rounded-md #{current_webform_id.to_s == wf.id.to_s ? 'bg-violet-600 text-white' : 'bg-gray-200 hover:bg-gray-300'}",
        data: { turbo: false } %>
  <% end %>
</div>

<div class="flex items-center justify-between mb-4">
  <div>
    <h1 class="text-xl font-semibold"><%= t("incases.index.title") %> <small class="text-sm text-gray-500"><%= @incases.total_entries %></small></h1>
    <p class="text-sm text-gray-600 mt-1">
      <%= t("incases.index.filter_total_label") %>:
      <%= number_to_currency(@incases_total_amount, unit: "₽", separator: ",", delimiter: " ", format: "%n %u") %>
    </p>
  </div>

  <div class="flex space-x-2">
    <%= search_form_for @search, url: account_incases_path(current_account), method: :get, html: { class: "flex items-center space-x-2" } do |f| %>
      <label class="flex items-center gap-1 text-sm text-gray-500">
        <%= t('products.index.created_from') %>
        <%= f.date_field :created_at_datebegin, value: params.dig(:q, :created_at_datebegin), class: "h-8 px-2 border rounded text-sm leading-none cursor-pointer", autocomplete: "off" %>
      </label>
      <label class="flex items-center gap-1 text-sm text-gray-500">
        <%= t('products.index.created_to') %>
        <%= f.date_field :created_at_dateend, value: params.dig(:q, :created_at_dateend), class: "h-8 px-2 border rounded text-sm leading-none cursor-pointer", autocomplete: "off" %>
      </label>
      <%= f.search_field :client_name_or_client_email_cont,
          value: params.dig(:q, :client_name_or_client_email_cont),
          placeholder: t('incases.index.search_placeholder'),
          class: "h-8 px-2 border rounded text-sm leading-none",
          style: "max-width: 200px;" %>
      <%= f.select :webform_id_eq, @webforms.pluck(:title, :id),
          { prompt: t('incases.index.webform')},
          { class: "h-8 px-2 border rounded text-sm leading-none", style: "max-width: 200px;" } %>
      <%= f.select :incase_status_id_eq, current_account.incase_statuses.ordered.map { |s| [s.name, s.id] },
          { prompt: t('incases.index.status')},
          { class: "h-8 px-2 border rounded text-sm leading-none" } %>

      <%= f.submit t('incases.index.search', default: 'Search'),
          class: "h-8 px-3 bg-gray-200 rounded hover:bg-gray-300 text-sm leading-none" %>
      <%= link_to_clear account_incases_path(current_account),
          class: "h-8 px-3 bg-gray-100 rounded hover:bg-gray-200 flex items-center text-sm leading-none" %>
    <% end %>
  </div>
</div>

<div class="mb-6 grid grid-cols-1 md:grid-cols-2 gap-4">
  <div class="bg-white rounded-lg shadow p-4">
    <h3 class="text-sm font-medium text-gray-700 mb-3"><%= t('incases.index.chart_title') %></h3>
    <div class="h-64">
      <canvas
        id="chart-by-day"
        data-controller="chartjs"
        data-chartjs-data-value="<%= @chart_data.to_json %>"
        data-chartjs-type-value="bar"
        data-chartjs-options-value='{"scales":{"y":{"beginAtZero":true}}}'
      ></canvas>
    </div>
  </div>
  <div class="bg-white rounded-lg shadow p-4">
    <h3 class="text-sm font-medium text-gray-700 mb-3"><%= t('incases.index.chart_title_by_status') %></h3>
    <div class="h-64">
      <canvas
        id="chart-by-status"
        data-controller="chartjs"
        data-chartjs-data-value="<%= @chart_data_by_status.to_json %>"
        data-chartjs-type-value="bar"
        data-chartjs-options-value='{"scales":{"x":{"stacked":true},"y":{"stacked":true,"beginAtZero":true}}}'
      ></canvas>
    </div>
  </div>
</div>

<div class="bg-white rounded-lg shadow divide-y">
  <div class="grid grid-cols-[80px_160px_120px_250px_250px_120px_2fr] gap-4 p-4 font-medium text-gray-700">
    <div>#</div>
    <div><%= t('incases.index.created_at') %></div>
    <div><%= t('incases.index.status') %></div>
    <div><%= t('incases.index.webform') %></div>
    <div><%= t('incases.index.client') %></div>
    <div><%= t('incases.index.totalsum') %></div>
    <div></div>
  </div>
  <%= turbo_frame_tag [dom_id(current_account), :incases] do %>
    <%= render @incases %>
    <%= render "shared/paginate", f: @incases %>
  <% end %>
</div>