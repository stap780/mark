<%= turbo_frame_tag dom_id(current_account, dom_id(campaign, dom_id(rule))) do %>
  <div class="grid grid-cols-[2fr_2fr_2fr_100px] gap-2 p-3 border rounded mb-2 bg-gray-50 items-center">
    <div class="text-sm"><%= campaign_filter_rule_field_label(rule.field) %></div>
    <div class="text-sm"><%= operator_label(rule.operator) %></div>
    <div class="text-sm"><%= rule.display_value %></div>
    <div class="flex justify-end items-center gap-1">
      <%= link_to_edit edit_account_campaign_campaign_filter_rule_path(current_account, campaign, rule),
          data: { turbo_frame: :offcanvas } %>
      <%= link_to_delete account_campaign_campaign_filter_rule_path(current_account, campaign, rule),
          data: { turbo_method: :delete, turbo_confirm: t("campaigns.form.remove_segment_rule_confirm"), turbo_stream: true } %>
    </div>
  </div>
<% end %>
