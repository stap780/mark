<%= turbo_frame_tag dom_id(incase_status), class: "grid grid-cols-[1fr_2fr_120px_150px] gap-4 p-4 items-center hover:bg-gray-50" do %>
  <div class="text-sm font-mono"><%= incase_status.key %></div>
  <div>
    <span class="px-2 py-1 text-xs font-medium rounded-full <%= incase_status.color %>">
      <%= incase_status.name %>
    </span>
  </div>
  <div class="text-sm text-gray-600 truncate"><%= incase_status.color %></div>
  <div class="flex justify-end space-x-2">
    <%= link_to_edit edit_account_incase_status_path(current_account, incase_status), data: { turbo_frame: :offcanvas } %>
    <%= link_to_delete account_incase_status_path(current_account, incase_status),
        data: { turbo_confirm: t("controllers.incase_statuses.destroy.confirm") } %>
  </div>
<% end %>
