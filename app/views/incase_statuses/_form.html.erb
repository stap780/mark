<%= form_with model: [current_account, incase_status], class: "space-y-4" do |f| %>
  <%= render "shared/errors", object: incase_status %>

  <%= f.hidden_field :position %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-violet-500 focus:ring-violet-500" %>
  </div>

  <div>
    <%= f.label :color, class: "block text-sm font-medium text-gray-700" %>
    <%= f.select :color,
        [
          ["Синий", "bg-blue-100 text-blue-800"],
          ["Жёлтый", "bg-yellow-100 text-yellow-800"],
          ["Зелёный", "bg-green-100 text-green-800"],
          ["Красный", "bg-red-100 text-red-800"],
          ["Серый", "bg-gray-100 text-gray-800"]
        ],
        {},
        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-violet-500 focus:ring-violet-500" %>
  </div>

  <div class="pt-2">
    <%= f.submit t("save", default: "Сохранить"), class: "px-4 py-2 bg-violet-600 text-white rounded-md hover:bg-violet-700" %>
  </div>
<% end %>
