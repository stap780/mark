<%# Canvas flowchart — layout передаётся из canvas_layout %>
<div class="border rounded-lg bg-gray-50 overflow-hidden" data-controller="flowchart" data-flowchart-connections-value="<%= layout[:connections].to_json %>">
  <div class="relative h-[700px] overflow-hidden" data-flowchart-target="viewport">
    <div class="absolute inset-0 overflow-auto flowchart-scroll" data-flowchart-target="scroll">
      <div class="relative min-w-full min-h-full p-4 bg-[radial-gradient(circle,#cbd5e1_1px,transparent_1px)] bg-[length:16px_16px]" data-flowchart-target="canvas" style="width: <%= layout[:canvas_size][:w] %>px; height: <%= layout[:canvas_size][:h] %>px;">
        <svg class="absolute inset-0 w-full h-full pointer-events-none" data-flowchart-target="svg" style="z-index: 1;">
          <defs>
            <marker id="arrowhead" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
              <polygon points="0 0, 10 3.5, 0 7" fill="#94a3b8" />
            </marker>
          </defs>
        </svg>
        <%= turbo_frame_tag dom_id(current_account, dom_id(automation_rule, :steps)), class: "absolute inset-0", style: "z-index: 2;", data: { flowchart_target: "stepsContainer" } do %>
          <%= render "automation_rules/steps_tree", automation_rule: automation_rule, current_account: current_account, layout: layout %>
        <% end %>
      </div>
    </div>
  </div>
  <div class="flex items-center gap-2 px-4 py-2 bg-white border-t">
    <button type="button" data-action="flowchart#zoomOut" class="px-2 py-1 text-sm font-medium text-gray-600 hover:bg-gray-100 rounded" aria-label="Уменьшить">−</button>
    <span data-flowchart-target="zoomLabel" class="text-sm text-gray-600 w-12 text-center">100%</span>
    <button type="button" data-action="flowchart#zoomIn" class="px-2 py-1 text-sm font-medium text-gray-600 hover:bg-gray-100 rounded" aria-label="Увеличить">+</button>
  </div>
</div>
